# ============================================================
# AIIA — AI Information Architecture
# Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# === Ollama (Local LLM — required) ===
# URL of your Ollama instance. Default: http://localhost:11434
OLLAMA_URL=http://localhost:11434

# Models to use (must be pulled in Ollama first)
AIIA_DEFAULT_MODEL=llama3.1:8b-instruct-q8_0
AIIA_FAST_MODEL=llama3.1:8b-instruct-q8_0
AIIA_TASK_MODEL=llama3.1:8b-instruct-q8_0

# === Long-context support (optional but recommended) ===
# Enables AIIA to handle up to 64K token contexts on 24GB machines via
# flash attention + 4-bit KV cache quantization. Trade-off: ~0.5% perplexity
# delta on standard benchmarks, 80× faster cold-load time vs uncompressed,
# ~4× memory reduction on the KV cache. See docs/long-context.md for
# benchmarks, trade-offs, and the launchd plist pattern for persistence
# across reboots on macOS.
#
# These env vars must reach the Ollama process. On macOS Homebrew installs,
# use `launchctl setenv` and then `brew services restart ollama`. In Docker,
# set them on the ollama service in docker-compose.yml (already wired).
OLLAMA_FLASH_ATTENTION=1
OLLAMA_KV_CACHE_TYPE=q4_0
OLLAMA_KEEP_ALIVE=24h

# === Anthropic Claude (Cloud LLM — optional) ===
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# === Google Gemini (Fallback LLM — optional) ===
# Get your key at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# === Supermemory (Cloud Memory — optional) ===
# Cloud memory sync. AIIA works fine without this.
# Get your key at: https://supermemory.ai
SUPERMEMORY_API_KEY=
SUPERMEMORY_ENABLED=true

# Container prefix for cloud memory (default: aiia)
AIIA_CONTAINER_PREFIX=aiia

# Path to SME domain config JSON (optional)
# AIIA_SME_CONFIG=/path/to/sme_containers.json

# === Data Directories ===
# Where AIIA stores knowledge, memory, and sync state
EQ_BRAIN_DATA_DIR=~/.aiia/eq_data

# === Local Brain API ===
LOCAL_BRAIN_HOST=0.0.0.0
LOCAL_BRAIN_PORT=8100

# === Command Center Dashboard ===
COMMAND_CENTER_PORT=8200

# === ChromaDB ===
# Collection name for the knowledge store
AIIA_COLLECTION_NAME=aiia_knowledge

# === Memory Sync Budget ===
# Token limits for metered cloud sync
SYNC_DAILY_TOKEN_LIMIT=100000
SYNC_MONTHLY_TOKEN_LIMIT=3000000

# === Production Monitor (optional) ===
# JSON file mapping service names to health check URLs.
# Loaded into AutonomyConfig.monitored_services at startup. Empty by
# default — the SelfHealingMonitor does nothing unless services are
# configured here.
# AIIA_SERVICES_CONFIG=/path/to/services.json
#
# Example services.json:
# [
#   {"name": "My API", "url": "https://my-api.example.com/health"},
#   {"name": "My Frontend", "url": "https://my-app.example.com"}
# ]

# === Phase 2 Autonomy (optional) ===
# Enables proactive autonomy features: auto story execution, stale
# GATED action downgrade, self-healing monitor, memory quality loop.
# Ship disabled — flip to "phase2" when you're ready to let AIIA act
# on its own outside business hours. See docs/autonomy.md (coming).
#
# AIIA_AUTONOMY_LEVEL=phase1
#
# Max severity auto-downgraded from GATED → SUPERVISED (low|medium|high)
# AIIA_AUTONOMY_MAX_SEVERITY=low
#
# IANA timezone for proactive business-hours check
# AIIA_BUSINESS_HOURS_TZ=UTC
#
# Optional URL probed before proactive execution runs. Leave unset to
# skip the gate (proactive runs whenever it's off-hours).
# AIIA_PROACTIVE_HEALTH_CHECK_URL=https://my-api.example.com/health

# === Products Config (optional) ===
# JSON file for product registry used by command center
# AIIA_PRODUCTS_CONFIG=/path/to/products.json

# === Google Cloud TTS (optional — for voice interface) ===
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
